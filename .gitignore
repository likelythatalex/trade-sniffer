# --- Secrets / environment ---
# Webhook URLs and any tokens come from env vars / GitHub Secrets, never the repo.
.env
.env.*
*.local

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Virtual environments ---
.venv/
venv/
env/

# --- Generated scanner output ---
# main is code-only: ALL scanner output (reports, watchlists, signals.csv, state.json)
# lives on the gh-pages branch, published by CI. Keep the dir but ignore its contents.
output/*
!output/.gitkeep
.cache/
data_cache/
*.cache

# --- IDE / editor ---
.vscode/
.idea/
*.swp

# --- OS noise ---
Thumbs.db
.DS_Store
