# --- Secrets / environment ---
# Webhook URLs and any tokens come from env vars / GitHub Secrets, never the repo.
.env
.env.*
*.local

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Virtual environments ---
.venv/
venv/
env/

# --- Generated scanner output ---
# main is code-only: ALL scanner output (reports, watchlists, signals.csv, state.json)
# lives on the gh-pages branch, published by CI. Keep the dir but ignore its contents.
output/*
!output/.gitkeep
.cache/
data_cache/
*.cache

# --- Backtest results (offline analysis tool; not part of the published scan) ---
backtest_results/

# --- Standalone review CLI output (code/outcome reviews; on-demand, not published) ---
review_out/

# --- Private trade journal (LOCAL ONLY — never committed, never published) ---
# The repo and gh-pages are PUBLIC; intended trades and their post-trade reviews stay on
# your machine. The journal runs locally/manually only, never in CI. See SPEC §8A.2.
journal.csv
journal_*.csv
journal_report*.html
trade_reviews.json

# --- Copyrighted reference material (LOCAL ONLY — never committed to a public repo) ---
# Third-party books/PDFs used as reference while building the strategy. We may paraphrase
# methodology into our own docs, but the source texts themselves stay off the repo.
docs/*.pdf

# --- IDE / editor ---
.vscode/
.idea/
*.swp

# --- OS noise ---
Thumbs.db
.DS_Store
